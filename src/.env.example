#Local-RAG Application Environment Variables

#App Settings
APP_NAME=Local-RAG
APP_VERSION=0.1.0

#File Upload Settings
FILE_ALLOWED_EXTENSIONS=["text/plain", "application/pdf", "application/vnd.openxmlformats-officedocument.wordprocessingml.document"]
FILE_MAX_SIZE_MB=5
FILE_CHUNK_SIZE=1024*1024

#MongoDB
MONGODB_URI=mongodb://admin:admin@localhost:27017
MONGODB_DB_NAME=Local-RAG

#Generation LLM (TODO: configure keys when ready)
# OPENAI_API_KEY=
# OPENAI_API_BASE=https://
# GENERATION_MODEL=

#Vector DB (ChromaDB)
VECTOR_DB_PATH=chroma_data
VECTOR_DB_DISTANCE_METRIC=cosine

#Langs
DEFAULT_LANGUAGE=en
